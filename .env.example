# bookmark-manager-api configuration
# Copy to .env and adjust as needed. All values have safe defaults if unset.

# HTTP port the server listens on.
# Must be a positive integer. Default: 3000.
PORT=3000

# Pino log level.
# One of: fatal | error | warn | info | debug | trace | silent
# Default: info. Tests force this to "silent" via jest.setup.js.
LOG_LEVEL=info

# Runtime mode. Default: development.
# One of: development | test | production
NODE_ENV=development
