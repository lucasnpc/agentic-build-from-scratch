{
  "name": "bookmark-manager-api",
  "version": "0.1.0",
  "private": true,
  "description": "A minimal bookmark manager REST API built incrementally with the Build-Verify-Commit workflow.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
